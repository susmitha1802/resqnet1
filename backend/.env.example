# Flask Session Secret Key
SECRET_KEY=your_secret_key

# JWT Token Encryption Key
JWT_SECRET_KEY=your_jwt_secret

# Database Connection URI (SQLite by default)
DATABASE_URL=sqlite:///resqnet.db

# OpenWeatherMap API Key for live weather and preparedness center
OPENWEATHER_API_KEY=your_openweather_api_key

# Flask Environment (development or production)
FLASK_ENV=development

# Enable or disable debug mode
FLASK_DEBUG=False

# Folder path for uploaded images and proofs
UPLOAD_FOLDER=backend/uploads