# ==========================================
# ResQNet — Environment Configuration
# ==========================================
# Copy this file to '.env' and fill in the values below.

# ── 1. Flask Configuration ──
# FLASK_DEBUG: Set to 'True' for development, 'False' for production.
# SECRET_KEY: Cryptographic key used by Flask for session cookies and security. MUST be kept secret.
FLASK_DEBUG=True
SECRET_KEY=CHANGE_ME

# ── 2. Database Configuration ──
# DATABASE_URL: The primary connection string. 
# For SQLite (default): sqlite:///resqnet.db
# For PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/resqnet
# For Neon PostgreSQL: postgresql+psycopg2://[user]:[password]@[endpoint].neon.tech/resqnet


# ── 3. JWT Configuration ──
# JWT_SECRET_KEY: Key used to cryptographically sign JSON Web Tokens for user authentication.
JWT_SECRET_KEY=CHANGE_ME

# ── 4. Admin Secret Codes ──
# ADMIN_SECRET_CODE: The passcode required during Registration to create an 'admin' account.
ADMIN_SECRET_CODE=CHANGE_ME

# ── 5. Map & Location Configuration ──
# MAP_PROVIDER: Defines which map engine to use. Default is 'leaflet'.
# LOCATION_API_KEY: Optional. If you switch from free Nominatim to Mapbox or LocationIQ, paste the API key here.
MAP_PROVIDER=leaflet
LOCATION_API_KEY=

# ── 6. File Uploads ──
# UPLOAD_FOLDER: Name of the local directory where images/files are saved.
# MAX_CONTENT_LENGTH: Max allowed upload size in bytes (default 10485760 = 10MB).
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760

# ── 7. CORS Configuration ──
# CORS_ORIGINS: Comma-separated list of allowed origins (domains) that can access this API.
# Use '*' to allow all during development, but restrict this in production!
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,*
